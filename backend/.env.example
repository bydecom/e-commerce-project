DATABASE_URL="postgresql://admin:secret123@localhost:5433/ecommerce"
REDIS_URL="redis://default:redissecret@localhost:6380"
RABBITMQ_URL="amqp://admin:secret123@localhost:5672"

MAIL_HOST="localhost"
MAIL_PORT=1025
MAIL_FROM="no-reply@ecommerce.local"

# Public base URL of this backend (used for email verification link)
API_BASE_URL="http://localhost:3000"

# Optional: enable HTTPS directly in Node.js (for local/staging).
# In production, it's also common to terminate TLS at a reverse proxy (Nginx/Traefik/Cloudflare)
# and keep Node on HTTP; in that case, leave HTTPS_ENABLED=false.
HTTPS_ENABLED=false
HTTPS_PORT=3443
TLS_KEY_PATH=""
TLS_CERT_PATH=""
HTTPS_REDIRECT=false

# Set true when behind a reverse proxy so Express trusts X-Forwarded-* headers.
TRUST_PROXY=false

# Object Storage (MinIO for dev, S3 for production)
AWS_ENDPOINT="http://localhost:9002"
AWS_ACCESS_KEY_ID="admin"
AWS_SECRET_ACCESS_KEY="password123"
AWS_BUCKET_NAME="ecommerce-products"
AWS_REGION="us-east-1"

# Email verification/pending-registration TTLs (seconds)
VERIFY_TOKEN_TTL_SECONDS=180
PENDING_REGISTER_TTL_SECONDS=1800

GEMINI_API_KEY="nhap_key_gemini_cua_ban_vao_day"
PORT=3000
CLIENT_URL="http://localhost:4200"

# VNPay sandbox
# TMN code and hash secret are issued by VNPay sandbox portal.
VNP_TMN_CODE="your_tmn_code"
VNP_HASH_SECRET="your_hash_secret"
VNP_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
# Where VNPay redirects the browser back to (frontend route recommended).
VNP_RETURN_URL="http://localhost:4200/checkout"

# Product detail cache TTL (seconds) in Redis.
# Keep low for demo so stock updates reflect quickly.
PRODUCT_DETAIL_CACHE_TTL_SECONDS=5

# Checkout stock reservation (Redis) to prevent oversell at "Checkout" time.
# Default: 900 seconds (15 minutes). Min: 60s. Max: 3600s.
CHECKOUT_RESERVATION_TTL_SECONDS=900
# JWT refresh token configuration
# Access token TTL (Bearer). Default fallback: 15m.
JWT_ACCESS_EXPIRES_IN="14m"

# Refresh token TTL (seconds). Stored in Redis (hashed) and rotated on every refresh.
REFRESH_TOKEN_TTL_SECONDS=900

# Idle auto-logout (seconds). Used when DB has no `idle_timeout_seconds` row; max 86400.
IDLE_TIMEOUT_SECONDS=900

JWT_SECRET="nhap_secret_key_vao_day"

# Login rate limiting — OTP soft-lockout after this many failed attempts (per email, 24-hour window)
LOGIN_ATTEMPT_LIMIT=4
LOGIN_ATTEMPT_TTL_SECONDS=86400

# OTP verification code TTL (seconds) and resend cooldown
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
