generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  DONE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum SentimentLabel {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ProductStatus {
  AVAILABLE   
  UNAVAILABLE 
  DRAFT       
}

enum ActionPlanStatus {
  PENDING
  IN_PROGRESS
  DONE
  REJECTED
}

enum OrderEventType {
  ORDER_STATUS_CHANGED
  PAYMENT_STATUS_CHANGED
  SYSTEM_LOG
}

model User {
  id            Int        @id @default(autoincrement())
  email         String     @unique
  password      String
  name          String?
  phone         String?
  provinceId    String?
  districtId    String?
  wardId        String?
  streetAddress String?
  fullAddress   String?
  role          Role       @default(USER)
  createdAt     DateTime   @default(now())

  orders              Order[]
  feedbacks           Feedback[]
  assignedActionPlans FeedbackActionPlan[]
  orderEvents         OrderEvent[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  products Product[]
}

model Product {
  id             Int         @id @default(autoincrement())
  name           String
  title_unaccent String?
  description    String?
  price          Float
  stock          Int
  imageUrl       String?
  status         ProductStatus @default(DRAFT)

  categoryId     Int
  category       Category    @relation(fields: [categoryId], references: [id])

  orderItems     OrderItem[]
  feedbacks      Feedback[]

  @@index([title_unaccent], name: "product_title_btree_idx")
  @@index([status, title_unaccent], name: "product_status_title_btree_idx")
  @@index([title_unaccent(ops: raw("gin_trgm_ops"))], type: Gin, name: "product_title_gin_idx")
}

model Order {
  id              Int           @id @default(autoincrement())
  userId          Int
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  total           Float
  shippingAddress String
  createdAt       DateTime      @default(now())              
  updatedAt       DateTime      @updatedAt                   

  user            User          @relation(fields: [userId], references: [id])
  items               OrderItem[]
  feedbacks           Feedback[]
  paymentTransactions PaymentTransaction[]
  events              OrderEvent[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  unitPrice Float

  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Feedback {
  id          Int             @id @default(autoincrement())
  userId      Int
  productId   Int
  orderId     Int         
  typeId      Int          
  rating      Int
  comment     String?
  sentiment   SentimentLabel?

  user        User            @relation(fields: [userId], references: [id])
  product     Product         @relation(fields: [productId], references: [id])
  order       Order           @relation(fields: [orderId], references: [id])
  type        FeedbackType    @relation(fields: [typeId], references: [id])
  actionPlans FeedbackActionPlan[]

  @@unique([orderId, productId]) 
}

model FeedbackActionPlan {
  id          Int              @id @default(autoincrement())
  feedbackId  Int
  title       String
  description String?
  status      ActionPlanStatus @default(PENDING)
  resolution  String?          @db.Text
  assigneeId  Int?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  feedback    Feedback         @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  assignee    User?            @relation(fields: [assigneeId], references: [id])
}

model FeedbackType {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?
  isActive    Boolean    @default(true) 

  feedbacks   Feedback[]
}

model StoreSetting {
  id          Int      @id @default(autoincrement())
  name        String
  address     String?
  phone       String?
  email       String?
  logoUrl     String?
  description String?
  updatedAt   DateTime @updatedAt
}

model SystemLog {
  id           Int      @id @default(autoincrement())
  method       String
  url          String
  status       Int
  responseTime Float
  createdAt    DateTime @default(now())
}

/// Cached AI mini-advice for admin dashboard; one row per calendar day (UTC).
model DashboardDailyInsight {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique @db.Date
  bullets   String[]
  createdAt DateTime @default(now())
}

model SystemConfig {
  key         String   @id
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PaymentTransaction {
  id                    Int      @id @default(autoincrement())
  orderId               Int
  vnp_TxnRef            String   @unique
  vnp_TransactionNo     String?
  vnp_Amount            Float?
  vnp_BankCode          String?
  vnp_PayDate           String?
  vnp_ResponseCode      String?
  vnp_TransactionStatus String?
  isSuccess             Boolean
  rawQuery              Json
  createdAt             DateTime @default(now())

  order                 Order    @relation(fields: [orderId], references: [id])

  @@index([vnp_TxnRef])
}

model OrderEvent {
  id            Int            @id @default(autoincrement())
  orderId       Int
  type          OrderEventType
  oldValue      String?
  newValue      String?
  note          String?
  changedById   Int?
  changedByRole Role?
  createdAt     DateTime       @default(now())

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy     User?          @relation(fields: [changedById], references: [id])

  @@index([orderId])
}
