{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "moduleResolution": "node",
    "resolveJsonModule": true
  },
  "include": ["index.ts", "src/**/*.ts", "src/**/*.d.ts", "prisma/**/*.ts"],
  "ts-node": {
    "files": true
  }
}
