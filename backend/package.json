{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch .env --ext ts,json,env --exec npx ts-node index.ts",
    "dev:prod": "nodemon --watch .env.production --ext ts,json,env --exec \"npx dotenv-cli -e .env.production -- npx ts-node index.ts\"",
    "start:prod": "npx dotenv-cli -e .env.production -- npx ts-node index.ts",
    "db:seed": "npx prisma db seed",
    "db:push:dev": "npx prisma db push",
    "db:push:prod": "dotenv -e .env.production -- npx prisma db push",
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --passWithNoTests --forceExit"
  },
  "prisma": {
    "seed": "npx ts-node prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
